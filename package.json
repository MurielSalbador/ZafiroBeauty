  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@Depilacion/env": "*",
    "@studio-freight/lenis": "^1.0.42",
    "dotenv": "^17.4.2",
    "lenis": "^1.3.23",
    "react-countup": "^6.5.3",
    "react-intersection-observer": "^10.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@Depilacion/config": "*",
    "@types/node": "^25.6.2",
    "turbo": "^2.9.12",
